// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadType {
  FOUNDER
  INVESTOR
}

enum LeadStatus {
  HOT
  GOOD
  MAYBE
  LOW
}

enum MvpStatus {
  IDEA
  IN_PROGRESS
  COMPLETED
}

model Lead {
  id         String      @id @default(cuid())
  fullName   String
  email      String      @unique
  phone      String
  linkedIn   String?

  type       LeadType

  score      Int         @default(0)
  status     LeadStatus  @default(MAYBE)

  founder    FounderProfile?
  investor   InvestorProfile?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model FounderProfile {
  id                  String      @id @default(cuid())

  startupName         String
  background          String
  problem             String

  mvpStatus           MvpStatus

  traction            String?
  teamSize            Int?
  fundingAsk          Float?
  validationEvidence  String?

  extraResponses      Json?

  leadId              String      @unique
  lead                Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model InvestorProfile {
  id                  String      @id @default(cuid())

  investmentThesis    String
  stageFocus          String
  chequeSize          Float?

  currentPortfolio    String?
  supportModel        String?
  deploymentTimeline  String?

  extraResponses      Json?

  leadId              String      @unique
  lead                Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
}