generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadType {
  FOUNDER
  INVESTOR
}

enum LeadStatus {
  HOT
  GOOD
  MAYBE
  LOW
}

enum MvpStatus {
  IDEA
  IN_PROGRESS
  COMPLETED
}

model Lead {
  id          String      @id @default(cuid())

  fullName    String
  email       String      @unique
  phone       String
  linkedIn    String?

  type        LeadType

  score       Int         @default(0)
  status      LeadStatus  @default(MAYBE)
  completed   Boolean     @default(false)

  founder      FounderProfile?
  investor     InvestorProfile?

  answers       Answer[]
  scoreDetails  ScoreBreakdown[]
  aiSummary     AiSummary?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model FounderProfile {
  id                  String      @id @default(cuid())

  role                String
  companyName         String
  startupDescription  String       

  background          String
  problem             String
  customer            String

  mvpStatus           MvpStatus
  mvpLink             String?

  traction            String?
  teamSize            Int?
  teamFullTime        String?

  fundingAsk          Float?
  fundingStage        String?
  useOfFunds          String?

  validationEvidence  String?
  notableBacking      String?

  leadId              String      @unique
  lead                Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model InvestorProfile {
  id                  String      @id @default(cuid())

  firmName            String
  roleAtFirm          String

  investmentThesis    String
  sectors             String

  stageFocus          String
  leadOrFollow        String

  chequeSize          Float?
  chequeRange         String?

  currentPortfolio    String?
  portfolioConflicts  String?

  supportModel        String
  handsOnLevel        String

  dealsPerYear        Int?
  capitalAvailable    String
  deploymentTimeline  String

  leadId              String      @unique
  lead                Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Answer {
  id           String   @id @default(cuid())

  questionId   String
  question     String
  answer       String

  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
}

model AiSummary {
  id              String   @id @default(cuid())

  summary         String
  strengths       String[]
  weaknesses      String[]
  recommendation  String

  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
}

model ScoreBreakdown {
  id          String   @id @default(cuid())

  criterion   String
  points      Int
  maxPoints   Int
  reason      String

  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}